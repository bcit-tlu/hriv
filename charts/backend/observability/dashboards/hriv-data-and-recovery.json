        "type": "query"
      },
      {
        "current": {
          "selected": true,
          "text": "All",
          "value": "$__all"
        },
        "hide": 0,
        "includeAll": true,
        "allValue": ".*",
        "label": "User role",
        "multi": true,
        "name": "user_role",
        "options": [],
        "query": "admin,instructor,student",
        "refresh": 1,
        "regex": "",
        "skipUrlSync": false,
        "sort": 1,
        "type": "custom"
      },
      {
        "current": {
          "selected": true,
          "text": "All",
          "value": "$__all"
        },
        "hide": 0,
        "includeAll": true,
        "allValue": ".*",
        "label": "Application version",
        "multi": true,
        "name": "application_version",
        "options": [],
        "datasource": {
          "type": "prometheus",
          "uid": "${prometheus}"
        },
        "query": "label_values(http_server_request_duration_seconds_count{service=~\"${component}\"}, service_version)",
        "refresh": 1,
        "regex": "",
        "skipUrlSync": false,
        "sort": 1,
        "type": "query"
      }
    ]
  },
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "timepicker": {},
  "timezone": "browser",
