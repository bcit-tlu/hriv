          "expr": "sum by (user_role) (count_over_time({service_name=~\"${component}\"} | event_name!=\"\" | event_synthetic!=\"true\" | user_role=~\"${user_role}\" [$__auto]))",
          "legendFormat": "{{user_role}}",
          "refId": "A"
        }
      ],
      "title": "Request volume by role",
      "type": "timeseries",
      "description": "Aggregate end-user activity split by application role. Helps distinguish broad user-impact incidents from admin-only workflows."
