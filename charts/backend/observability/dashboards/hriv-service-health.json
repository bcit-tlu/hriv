          "datasource": {
            "type": "prometheus",
            "uid": "${prometheus}"
          },
          "expr": "sum(rate(http_server_request_duration_seconds_count{service=~\"${component}\",http_status_code=~\"5..\"}[5m])) / clamp_min(sum(rate(http_server_request_duration_seconds_count{service=~\"${component}\"}[5m])), 0.001)",
          "refId": "A"
        }
      ],
      "title": "Error Rate (5xx)",
      "type": "gauge",
      "description": "5xx ratio with a protected denominator so an idle period does not render as NaN or an outage."
    },
