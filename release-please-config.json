{
  "$schema": "https://raw.githubusercontent.com/googleapis/release-please/main/schemas/config.json",
  "bump-minor-pre-major": true,
  "include-component-in-tag": true,
  "separate-pull-requests": true,
  "versioning": "prerelease",
  "prerelease": true,
  "prerelease-type": "rc",
  "packages": {
    "frontend": {
      "release-type": "simple",
      "component": "frontend",
      "extra-files": [
        "package.json"
      ]
    },
    "backend": {
      "release-type": "simple",
      "component": "backend"
    },
    "backup": {
      "release-type": "simple",
      "component": "backup"
    }
  }
}
