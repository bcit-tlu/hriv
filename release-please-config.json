{
    "include-component-in-tag": true,
    "separate-pull-requests": true,
    "packages": {
        "frontend": {
            "path": "frontend",
            "component": "frontend",
            "release-type": "node",
            "extra-files": [
                {
                    "type": "yaml",
                    "path": "charts/frontend/Chart.yaml",
                    "jsonpath": "$.version"
                },
                {
                    "type": "yaml",
                    "path": "charts/frontend/Chart.yaml",
                    "jsonpath": "$.appVersion"
                }
            ]
        },
        "backend": {
            "path": "backend",
            "component": "backend",
            "release-type": "python",
            "extra-files": [
                {
                    "type": "yaml",
                    "path": "charts/backend/Chart.yaml",
                    "jsonpath": "$.version"
                },
                {
                    "type": "yaml",
                    "path": "charts/backend/Chart.yaml",
                    "jsonpath": "$.appVersion"
                }
            ]
        },
        "backup": {
            "path": "backup",
            "component": "backup",
            "release-type": "python",
            "extra-files": [
                {
                    "type": "yaml",
                    "path": "charts/backup/Chart.yaml",
                    "jsonpath": "$.version"
                },
                {
                    "type": "yaml",
                    "path": "charts/backup/Chart.yaml",
                    "jsonpath": "$.appVersion"
                }
            ]
        }
    }
}
