CVE-2026-32636  # sev=high
CVE-2026-33535  # sev=medium
CVE-2026-33536  # sev=medium
CVE-2026-33899  # sev=medium
CVE-2026-33900  # sev=medium
CVE-2026-33901  # sev=high
CVE-2026-33902  # sev=medium
CVE-2026-33905  # sev=medium
CVE-2026-33908  # sev=high
CVE-2026-34238  # sev=medium
CVE-2026-40169  # sev=medium
