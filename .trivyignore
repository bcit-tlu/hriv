CVE-2017-14988  # sev=low
CVE-2025-12495  # sev=high
CVE-2025-12839  # sev=high
CVE-2025-12840  # sev=high
CVE-2025-48074  # sev=medium
CVE-2025-64181  # sev=high
CVE-2026-27622  # sev=high
CVE-2026-34379  # sev=high
CVE-2026-34380  # sev=medium
CVE-2026-34543  # sev=high
CVE-2026-34544  # sev=high
CVE-2026-34545  # sev=high
CVE-2026-34588  # sev=high
CVE-2026-34589  # sev=medium

# --- ImageMagick core (HRIV uses pyvips directly, never shells out to IM) ----
# libmagickcore is a transitive Depends of libvips42t64 via libvips' delegates
# graph. HRIV never shells out to ImageMagick (`convert`, `magick`) and never
# invokes libvips' ImageMagick loader delegate — it opens TIFF/SVS directly
# via libtiff. Codec path unreachable.
#
# Packages: libmagickcore-7.q16-10
CVE-2005-0406   # sev=low
CVE-2008-3134   # sev=low
CVE-2016-8678   # sev=low
