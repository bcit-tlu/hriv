# Backend .env for local OIDC testing against HashiCorp Vault IdP
# Copy to backend/.env and fill in the placeholder values.
#
# Usage:
#   cp backend/.env.vault-example backend/.env
#   # Edit OIDC_CLIENT_SECRET with the real value from Vault
#   docker compose up --build

# --- Core backend settings (local Docker defaults) ---
DATABASE_URL=postgresql+asyncpg://hriv:hriv@db:5432/hriv
SOURCE_IMAGES_DIR=/data/source_images
TILES_DIR=/data/tiles
REDIS_URL=redis://redis:6379
JWT_SECRET=change-me-local-dev-secret

# Ensure backend can redirect back to your frontend after OIDC login
CORS_ORIGINS=http://localhost:5173

# --- OIDC / OAuth2 settings (Vault provider) ---
OIDC_ENABLED=true

# IMPORTANT: This must be the full Vault OIDC provider path including port
# and /v1/identity/oidc/provider/<name>.  The backend appends
# /.well-known/openid-configuration to discover endpoints automatically.
OIDC_ISSUER=https://vault.ltc.bcit.ca:8200/v1/identity/oidc/provider/vault-provider

# Client ID registered in Vault for HRIV
OIDC_CLIENT_ID=hkPdYUJqqEYWxiVwIrgrAjiS8fLja2ip

# Client secret — retrieve from Vault admin (Terraform output, UI, or CLI).
# This is the only value you MUST replace before testing.
OIDC_CLIENT_SECRET=replace-with-your-vault-client-secret

# Must match the redirect URI registered in the Vault OIDC client config
OIDC_REDIRECT_URI=http://localhost:8000/api/auth/oidc/callback
OIDC_SCOPES=openid email profile

# Map Vault identity groups to HRIV roles (JSON object)
OIDC_ROLE_MAPPING={"bcit-tlu-admins":"admin","bcit-tlu-instructors":"instructor","bcit-tlu-students":"student"}

# Where to redirect after successful OIDC login
OIDC_POST_LOGIN_REDIRECT=http://localhost:5173

# Vault does not emit email_verified; trust corporate IdP emails
OIDC_TRUST_EMAIL=true
