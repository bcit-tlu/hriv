# Backend local environment for OIDC testing against Vault IdP

# --- Core backend settings (local defaults) ---
DATABASE_URL=postgresql+asyncpg://hriv:hriv@localhost:5432/hriv
SOURCE_IMAGES_DIR=/data/source_images
TILES_DIR=/data/tiles
REDIS_URL=redis://localhost:6379
JWT_SECRET=change-me-local-dev-secret

# Ensure backend can redirect back to your frontend after OIDC login
CORS_ORIGINS=http://localhost:5173

# --- OIDC / OAuth2 settings ---
OIDC_ENABLED=true
OIDC_ISSUER=https://vault.ltc.bcit.ca
OIDC_CLIENT_ID=replace-with-your-vault-client-id
OIDC_CLIENT_SECRET=replace-with-your-vault-client-secret
OIDC_REDIRECT_URI=http://localhost:8000/api/auth/oidc/callback
OIDC_SCOPES=openid email profile

# Optional role mapping (JSON object as string)
OIDC_ROLE_MAPPING={"bcit-tlu-admins":"admin","bcit-tlu-instructors":"instructor","bcit-tlu-students":"student"}

# Recommended for local testing to guarantee post-login redirect target
OIDC_POST_LOGIN_REDIRECT=http://localhost:5173

# Vault often does not emit email_verified; enable trusted-email linking for corporate IdP use
OIDC_TRUST_EMAIL=true
